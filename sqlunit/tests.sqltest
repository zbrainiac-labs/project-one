# SQL Validation Tests for project-one
# Format: description | sql | expected
#
# --- Object Existence ---
ONEO_RAW_TB_WH_SIZE_RECOMMENDATION table exists | SELECT CASE WHEN COUNT(*) > 0 THEN 'true' ELSE 'false' END AS result FROM {{DATABASE}}.INFORMATION_SCHEMA.TABLES WHERE TABLE_SCHEMA = '{{SCHEMA}}' AND TABLE_NAME = 'ONEO_RAW_TB_WH_SIZE_RECOMMENDATION'; | true
Warehouse recommendations loaded | SELECT CASE WHEN COUNT(*) = 6 THEN 'true' ELSE 'false' END AS result FROM {{DATABASE}}.{{SCHEMA}}.ONEO_RAW_TB_WH_SIZE_RECOMMENDATION; | true
#
# --- Rule 10: Table naming {DOM}{COMP}_{MAT}_TB_ (OK) ---
rule_10_ok Table IOTI_RAW_TB_WH_SIZE_RECOMMENDATION follows naming | SELECT CASE WHEN COUNT(*) > 0 THEN 'true' ELSE 'false' END AS result FROM {{DATABASE}}.INFORMATION_SCHEMA.TABLES WHERE TABLE_SCHEMA = '{{SCHEMA}}' AND TABLE_NAME RLIKE '^[A-Z0-9]{3}[A-Z]_(RAW|CUR|AGG|GOL)_TB_.*'; | true
rule_10_nok Table IOT_RAW violates naming convention | SELECT CASE WHEN COUNT(*) > 0 THEN 'true' ELSE 'false' END AS result FROM {{DATABASE}}.INFORMATION_SCHEMA.TABLES WHERE TABLE_SCHEMA = '{{SCHEMA}}' AND TABLE_NAME = 'IOT_RAW' AND TABLE_NAME NOT RLIKE '^[A-Z0-9]{3}[A-Z]_(RAW|CUR|AGG|GOL)_TB_.*'; | true
#
# --- Rule 11: View naming {DOM}{COMP}_{MAT}_VW_ (OK) ---
rule_11_ok All views follow naming convention | SELECT CASE WHEN COUNT(*) = 0 THEN 'true' ELSE 'false' END AS result FROM {{DATABASE}}.INFORMATION_SCHEMA.VIEWS WHERE TABLE_SCHEMA = '{{SCHEMA}}' AND TABLE_NAME NOT RLIKE '^[A-Z0-9]{3}[A-Z]_(RAW|CUR|AGG|GOL)_VW_.*'; | true
#
# --- Rule 12: Dynamic Table naming {DOM}{COMP}_{MAT}_DT_ (OK) ---
rule_12_ok Dynamic table IOTI_RAW_DT_IOT_MIRROR follows naming | SELECT CASE WHEN COUNT(*) > 0 THEN 'true' ELSE 'false' END AS result FROM {{DATABASE}}.INFORMATION_SCHEMA.TABLES WHERE TABLE_SCHEMA = '{{SCHEMA}}' AND TABLE_NAME = 'IOTI_RAW_DT_IOT_MIRROR' AND TABLE_TYPE = 'DYNAMIC TABLE'; | true
#
# --- Rule 13: Stage naming {DOM}{COMP}_{MAT}_ST_ (OK) ---
rule_13_ok Stage IOTI_RAW_ST_DATA_LANDING follows naming | SELECT CASE WHEN COUNT(*) > 0 THEN 'true' ELSE 'false' END AS result FROM {{DATABASE}}.INFORMATION_SCHEMA.STAGES WHERE STAGE_SCHEMA = '{{SCHEMA}}' AND STAGE_NAME = 'IOTI_RAW_ST_DATA_LANDING'; | true
#
# --- Rule 20: No FLOAT columns (NOK - IOT_RAW uses FLOAT) ---
rule_20_nok IOT_RAW has FLOAT columns (known violation) | SELECT CASE WHEN COUNT(*) > 0 THEN 'true' ELSE 'false' END AS result FROM {{DATABASE}}.INFORMATION_SCHEMA.COLUMNS WHERE TABLE_SCHEMA = '{{SCHEMA}}' AND TABLE_NAME = 'IOT_RAW' AND DATA_TYPE = 'FLOAT'; | true
rule_20_ok IOTI_RAW_TB_WH_SIZE_RECOMMENDATION has no FLOAT columns | SELECT CASE WHEN COUNT(*) = 0 THEN 'true' ELSE 'false' END AS result FROM {{DATABASE}}.INFORMATION_SCHEMA.COLUMNS WHERE TABLE_SCHEMA = '{{SCHEMA}}' AND TABLE_NAME = 'IOTI_RAW_TB_WH_SIZE_RECOMMENDATION' AND DATA_TYPE = 'FLOAT'; | true
#
# --- Rule 21: VARCHAR must have explicit length (OK) ---
rule_21_ok VARCHAR columns have explicit length | SELECT CASE WHEN COUNT(*) = 0 THEN 'true' ELSE 'false' END AS result FROM {{DATABASE}}.INFORMATION_SCHEMA.COLUMNS WHERE TABLE_SCHEMA = '{{SCHEMA}}' AND DATA_TYPE = 'TEXT' AND CHARACTER_MAXIMUM_LENGTH = 16777216 AND TABLE_NAME = 'IOTI_RAW_TB_WH_SIZE_RECOMMENDATION'; | true
#
# --- Rule 22: Tables must have COMMENT (OK/NOK) ---
rule_22_ok IOTI_RAW_TB_WH_SIZE_RECOMMENDATION has comment | SELECT CASE WHEN COMMENT IS NOT NULL AND COMMENT != '' THEN 'true' ELSE 'false' END AS result FROM {{DATABASE}}.INFORMATION_SCHEMA.TABLES WHERE TABLE_SCHEMA = '{{SCHEMA}}' AND TABLE_NAME = 'IOTI_RAW_TB_WH_SIZE_RECOMMENDATION'; | true
rule_22_ok IOT_RAW has comment | SELECT CASE WHEN COMMENT IS NOT NULL AND COMMENT != '' THEN 'true' ELSE 'false' END AS result FROM {{DATABASE}}.INFORMATION_SCHEMA.TABLES WHERE TABLE_SCHEMA = '{{SCHEMA}}' AND TABLE_NAME = 'IOT_RAW'; | true
#
# --- Rule 07: Only TIMESTAMP_TZ allowed (OK - no timestamp cols in project) ---
rule_07_ok No TIMESTAMP_NTZ or TIMESTAMP_LTZ columns | SELECT CASE WHEN COUNT(*) = 0 THEN 'true' ELSE 'false' END AS result FROM {{DATABASE}}.INFORMATION_SCHEMA.COLUMNS WHERE TABLE_SCHEMA = '{{SCHEMA}}' AND DATA_TYPE IN ('TIMESTAMP_NTZ', 'TIMESTAMP_LTZ'); | true
#
# --- Rule 04: No grants to PUBLIC ---
rule_04_ok No table grants to PUBLIC | SELECT CASE WHEN COUNT(*) = 0 THEN 'true' ELSE 'false' END AS result FROM {{DATABASE}}.INFORMATION_SCHEMA.TABLE_PRIVILEGES WHERE TABLE_SCHEMA = '{{SCHEMA}}' AND GRANTEE = 'PUBLIC'; | true
#
# --- Rule 25: Dynamic Tables have TARGET_LAG ---
rule_25_ok Dynamic table IOTI_RAW_DT_IOT_MIRROR has target lag | SELECT CASE WHEN TARGET_LAG IS NOT NULL THEN 'true' ELSE 'false' END AS result FROM {{DATABASE}}.INFORMATION_SCHEMA.DYNAMIC_TABLES WHERE SCHEMA_NAME = '{{SCHEMA}}' AND NAME = 'IOTI_RAW_DT_IOT_MIRROR'; | true
